{
  "name": "bjobs-enhancer",
  "type": "module",
  "version": "0.2.0",
  "description": "Improve your BDJobs browsing experience.",
  "author": "Shaikh Shafeen <shafeen@duck.com> (https://github.com/kurtnettle)",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/kurtnettle/bjobs-enhancer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kurtnettle/bjobs-enhancer.git"
  },
  "bugs": {
    "url": "https://github.com/kurtnettle/bjobs-enhancer/issues"
  },
  "keywords": [
    "bdjobs",
    "browser-extension",
    "brave",
    "chrome",
    "chromium",
    "edge",
    "firefox",
    "librewolf",
    "customization",
    "dark-mode",
    "filtering",
    "job-search",
    "productivity",
    "ui-enhancements"
  ],
  "scripts": {
    "dev": "wxt",
    "dev:ff": "wxt -b firefox",
    "build": "wxt build",
    "build:ff": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:ff": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@lucide/svelte": "^1.18.0",
    "@tailwindcss/vite": "^4.3.1",
    "svelte": "^5.56.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@eslint-react/eslint-plugin": "^5.9.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.2",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-svelte": "^2.0.5",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "mode-watcher": "^1.1.0",
    "shadcn-svelte": "^1.3.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "wxt": "^0.20.26"
  }
}
